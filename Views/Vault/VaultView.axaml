<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Password_manager.ViewModels"
             xmlns:models="using:Password_manager.Models"
             x:Class="Password_manager.Views.VaultView"
             x:DataType="vm:VaultViewModel">

    <Grid
        Margin="24"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,*">

        <StackPanel
            Grid.Row="0"
            Spacing="4"
            HorizontalAlignment="Center"
            Width="760">
                <TextBlock
                    Text="Your password vault"
                    HorizontalAlignment="Center"
                    FontSize="28"
                    FontWeight="Bold" />

                <TextBlock
                    Text="Manage passwords from one place"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    Opacity="0.7" />

                <Grid
                    Margin="0,16,0,0"
                    ColumnDefinitions="2*,2*,2*,Auto"
                    ColumnSpacing="8"
                    HorizontalAlignment="Stretch">

                    <TextBox
                        PlaceholderText="Website"
                        MaxLength="100" />

                    <TextBox
                        Grid.Column="1"
                        PlaceholderText="Username"
                        MaxLength="100" />

                    <TextBox
                        Grid.Column="2"
                        PlaceholderText="Password"
                        PasswordChar="*"
                        MaxLength="100" />

                    <Button
                        Grid.Column="3"
                        Content="Add new password"
                        VerticalAlignment="Center"
                        MinWidth="180"
                        Click="AddNewPasswordButton_Click" />
                </Grid>

                <TextBox
                    Text="{Binding SearchQuery, Mode=TwoWay}"
                    PlaceholderText="Search passwords..."
                    Margin="0,16,0,0" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,16,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Width="760"
                Padding="16"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="16">

                <ScrollViewer
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">

                    <ItemsControl
                        ItemsSource="{Binding FilteredPasswordEntries}"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Border
                                    Padding="14"
                                    Background="{DynamicResource SystemControlBackgroundAltLowBrush}"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5">

                                    <Grid ColumnDefinitions="2*,2*,1.4*,Auto" ColumnSpacing="14" VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Text="{Binding Website}"
                                                FontSize="16"
                                                FontWeight="SemiBold" />
                                            <TextBlock
                                                Text="Website"
                                                FontSize="11"
                                                Opacity="0.55" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock
                                                Text="{Binding Username}"
                                                FontSize="15" />
                                            <TextBlock
                                                Text="Username"
                                                FontSize="11"
                                                Opacity="0.55" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <TextBlock
                                                Text="{Binding Password}"
                                                FontSize="15" />
                                            <TextBlock
                                                Text="Password"
                                                FontSize="11"
                                                Opacity="0.55" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="3"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                            <Button
                                                Content="Edit"
                                                Click="EditButton_Click" />
                                            <Button
                                                Content="Delete"
                                                Click="DeleteButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
